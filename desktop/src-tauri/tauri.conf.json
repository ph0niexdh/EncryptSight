{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EncryptSight",
  "version": "1.0.0",
  "identifier": "com.encryptsight.desktop",
  "build": { "beforeBuildCommand": "npm --prefix ../frontend run build", "beforeDevCommand": "npm --prefix ../frontend run dev", "devUrl": "http://localhost:5173", "frontendDist": "../../frontend/dist" },
